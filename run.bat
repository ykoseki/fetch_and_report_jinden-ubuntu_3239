@echo off
chcp 65001 > nul
echo 🚀 業務改善報告書 自動生成ツール を起動します 🚀
echo.
echo 📅 レポートを作成したい年月を入力してください。
echo (何も入力せずにEnterを押すと、デフォルト値が使われます)
echo.

set /p y=📅 年度 (YYYY) [デフォルト=2026]: 
if "%y%"=="" set y=2026

set /p m=📅 月 (MM) [デフォルト=3]: 
if "%m%"=="" set m=3

echo.
echo 📥 { %y%年 %m%月 } のデータを取得してレポートを作成中...
echo ----------------------------------------------------------
echo.

python fetch_and_report.py --year %y% --month %m%

echo.
echo ----------------------------------------------------------
echo ✨ 処理が完了しました！フォルダの中にエクセルができているか確認してね 💖
echo ----------------------------------------------------------
echo.
pause
