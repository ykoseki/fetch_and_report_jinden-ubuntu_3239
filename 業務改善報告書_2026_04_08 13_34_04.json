        "Scripts": [
          {
            "Title": "メールタイトルに「<Site_Title>：」を追加",
            "Edit": true,
            "Body": "$(document).on('click',\"#EditOutgoingMail\",function (){\n    const apiGetPromisify = (siteId) => {\n        return new Promise((resolve, reject) => {\n            $p.apiGetSite({\n                id: siteId,\n                done: function (data) {\n                    //console.log(data);\n                    // console.log(data.Response.Data.Title);\n                    console.log('サイト情報の作成に成功しました。');\n                    resolve(data);\n                },\n                fail: function (data) {\n                    console.log('サイト情報の作成に失敗しました。');\n                    reject(data);\n                },\n                // always: function () {\n                //     console.log('サイト情報の作成が完了しました。');\n                // },\n            });\n        });\n    };\n    const apiGetPromisify2 = (siteId, resultId) => {\n        return new Promise((resolve, reject) => {\n          $p.apiGet({\n            id: siteId,\n            data: {\n              View: {\n                ColumnFilterHash: { ResultId: JSON.stringify(resultId) },\n              },\n            },\n            done: function (data) {\n                console.log('情報の作成に成功しました。');\n                // console.log({'TotalCount':data.Response.TotalCount,'PageSize':data.Response.PageSize,'Offset':data.Response.Offset});\n                // console.log(data);\n                resolve(data);\n            },\n            fail: function (data) {\n                console.log('情報の作成に失敗しました。');\n                reject(data);\n            },\n          });\n        });\n    };\n    //data:{view:{\n    // ApiDataType: 'KeyValues',\n    // GridColumns: ['ResultId', 'Title'], -> ID,件名\n    const setMailTitle = async() => {\n        const SiteTitle = (await apiGetPromisify($p.siteId())).Response.Data.Title;\n        const RecordTitle = (await apiGetPromisify2($p.siteId(), $p.id())).Response.Data[0].Title;\n        console.log($p.siteId());\n        console.log(SiteTitle);\n        console.log(JSON.stringify($p.id()));\n        console.log(RecordTitle);\n        //NG const title = $(\"#Results_Title\").text();\n        // const title = $(\"#OutgoingMails_Title\").val();\n        // console.log(title);\n        // let mailTitle = `${SiteTitle}：${title}`;\n        let mailTitle = `${SiteTitle}：${RecordTitle}`;\n        console.log(mailTitle);\n        $p.set($(\"#OutgoingMails_Title\"), mailTitle);\n    };\n\n    setMailTitle ();\n})\n",
            "Id": 2
          },
          {
            "Title": "console.log",
            "All": true,
            "Body": "console.log( $('#Results_Owner').text() ) ;\nconsole.log( $('#Results_Owner').val() ) ;",
            "Id": 3
          }
        ],
